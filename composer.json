{
  "name": "milpa/auth-webauthn",
  "description": "Passkey / WebAuthn for the Milpa PHP framework: the WebAuthnVerifier, ChallengeStore and WebAuthnCredentialStore contracts, ceremony value objects, in-memory defaults, and a lbuchs adapter. A verified assertion mints a session \u2014 it is never a per-request transport. Zero framework, zero ORM.",
  "type": "library",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Rodrigo Vicente - TeamX Agency",
      "homepage": "https://teamx.agency"
    }
  ],
  "require": {
    "php": ">=8.3",
    "milpa/auth": "^0.2",
    "lbuchs/webauthn": "^2",
    "psr/http-message": "^1 || ^2",
    "ext-openssl": "*",
    "ext-mbstring": "*",
    "ext-sodium": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpdoc-parser": "^2.3",
    "friendsofphp/php-cs-fixer": "^3.65",
    "milpa/core": "*"
  },
  "autoload": {
    "psr-4": {
      "Milpa\\Auth\\WebAuthn\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Milpa\\Auth\\WebAuthn\\Tests\\": "tests/",
      "Milpa\\Docs\\": "vendor/milpa/core/tools/gen-docs/"
    }
  }
}
